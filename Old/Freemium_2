    <script>
        // ===== SUPABASE CONFIG =====
        // TODO: paste your project URL + anon (public) key here
        const SUPABASE_URL     = 'https://qajjuhjmrtuomwrbxmpz.supabase.co';
        const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFhamp1aGptcnR1b213cmJ4bXB6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0NTMzNTksImV4cCI6MjA5MDAyOTM1OX0.4tyFG-e2IIh0Iwze7TQorfRF7DqUQkGBpeRgCcMkFC4';

        // ===== STORAGE KEYS =====
        const KEY_NAME = 't7_freemium_player_name';
        const KEY_XP   = 't7_freemium_xp';
        const KEY_DONE = 't7_freemium_completed';
        const XP_PER_TRICK = 25;

        // ===== STATE (localStorage wrapper) =====
        const State = {
            getName() { return localStorage.getItem(KEY_NAME) || ''; },
            setName(name) { localStorage.setItem(KEY_NAME, name); },
            clearName() { localStorage.removeItem(KEY_NAME); },
            getXP() { return parseInt(localStorage.getItem(KEY_XP) || '0', 10); },
            addXP(n) {
                const next = this.getXP() + n;
                localStorage.setItem(KEY_XP, String(next));
                return next;
            },
            getDone() {
                try { return new Set(JSON.parse(localStorage.getItem(KEY_DONE) || '[]')); }
                catch { return new Set(); }
            },
            markDone(id) {
                const done = this.getDone();
                if (done.has(id)) return false;
                done.add(id);
                localStorage.setItem(KEY_DONE, JSON.stringify([...done]));
                return true;
            }
        };

        // ===== SUPABASE CLIENT (or null if not configured) =====
        let sb = null;
        if (SUPABASE_URL && SUPABASE_ANON_KEY && window.supabase) {
            sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        }

        // ===== MOCK DATA (used until Supabase config is filled in) =====
        const MOCK = {
            stars: [
                { id: 'm-s1', title: 'Around the World', stars: 1, sevens: null, duration_sec: 180, video_url: '#' },
                { id: 'm-s2', title: 'Toe Bounce',       stars: 1, sevens: null, duration_sec: 150, video_url: '#' },
                { id: 'm-s3', title: 'Knee Catch',        stars: 2, sevens: null, duration_sec: 210, video_url: '#' },
                { id: 'm-s4', title: 'Hop the Ball',      stars: 3, sevens: null, duration_sec: 240, video_url: '#' }
            ],
            sevens: [
                { id: 'm-v1', title: 'Pass mit Innenseite',   stars: null, sevens: 1, duration_sec: 165, video_url: '#' },
                { id: 'm-v2', title: 'Ballannahme & Mitnahme', stars: null, sevens: 1, duration_sec: 195, video_url: '#' },
                { id: 'm-v3', title: 'Schussbewegung',         stars: null, sevens: 2, duration_sec: 230, video_url: '#' }
            ],
            challenges: [
                { id: 'm-c1', title: 'Hocus Pocus',            stars: 4, sevens: null, duration_sec: 280, video_url: '#' },
                { id: 'm-c2', title: 'Around the World Double', stars: 5, sevens: null, duration_sec: 360, video_url: '#' },
                { id: 'm-c3', title: 'Sevens Schuss-Trick',     stars: null, sevens: 3, duration_sec: 300, video_url: '#' }
            ]
        };

        // ===== DATA FETCH =====
        async function fetchSection(key) {
            if (!sb) return MOCK[key];
            try {
                let q;
                if (key === 'stars') {
                    q = sb.from('videos').select('*').eq('freemium', true).in('stars', [1, 2, 3]);
                } else if (key === 'sevens') {
                    q = sb.from('videos').select('*').eq('freemium', true).in('sevens', [1, 2]);
                } else { // challenges
                    q = sb.from('videos').select('*').eq('freemium', true)
                        .or('stars.in.(4,5),sevens.eq.3');
                }
                const { data, error } = await q;
                if (error) throw error;
                return data || [];
            } catch (err) {
                console.error('[freemium] supabase fetch failed for', key, err);
                return null; // null signals error so UI can show it
            }
        }

        // ===== RENDERING =====
        const fmtDuration = sec => {
            if (!sec) return '';
            const m = Math.floor(sec / 60);
            const s = sec % 60;
            return `${m}:${String(s).padStart(2, '0')}`;
        };

        const tagFor = v => {
            if (v.stars != null)  return `${v.stars} Sterne`;
            if (v.sevens != null) return `Sevens · Level ${v.sevens}`;
            return '';
        };

        function videoCardHTML(v, done) {
            const isDone = done.has(v.id);
            const thumb = v.thumbnail_url
                ? `<img src="${v.thumbnail_url}" alt="${v.title}" loading="lazy">`
                : `<div class="video-thumb-placeholder">▶</div>`;
            const duration = v.duration_sec ? `<span class="video-duration">${fmtDuration(v.duration_sec)}</span>` : '';
            const btn = isDone
                ? `<button class="xp-btn done" disabled>✓ Geschafft</button>`
                : `<button class="xp-btn" data-id="${v.id}">+${XP_PER_TRICK} XP — Geübt!</button>`;
            return `
                <div class="video-card">
                    <a class="video-thumb" href="${v.video_url || '#'}" target="_blank" rel="noopener">
                        ${thumb}
                        ${duration}
                    </a>
                    <div class="video-meta">
                        <div class="video-tag">${tagFor(v)}</div>
                        <h3 class="video-title">${v.title || 'Ohne Titel'}</h3>
                        ${btn}
                    </div>
                </div>
            `;
        }

        async function renderGrid(key, gridId) {
            const grid = document.getElementById(gridId);
            const videos = await fetchSection(key);
            if (videos === null) {
                grid.innerHTML = `<div class="grid-status error">Konnte Videos nicht laden. Bitte später erneut versuchen.</div>`;
                return;
            }
            if (!videos.length) {
                grid.innerHTML = `<div class="grid-status">Noch keine Videos in dieser Sektion.</div>`;
                return;
            }
            const done = State.getDone();
            grid.innerHTML = videos.map(v => videoCardHTML(v, done)).join('');
            grid.querySelectorAll('.xp-btn:not(.done)').forEach(btn => {
                btn.addEventListener('click', () => {
                    const id = btn.dataset.id;
                    if (!State.markDone(id)) return;
                    State.addXP(XP_PER_TRICK);
                    btn.classList.add('done');
                    btn.disabled = true;
                    btn.innerHTML = '✓ Geschafft';
                    updateXP(true);
                });
            });
        }

        // ===== UI: name + XP =====
        function updateName() {
            const name = State.getName();
            const setup     = document.getElementById('nameSetup');
            const stats     = document.getElementById('playerStats');
            const greetTail = document.getElementById('greetingName');
            const welcome   = document.getElementById('welcomeMsg');
            const display   = document.getElementById('nameDisplay');

            if (name) {
                setup.hidden = true;
                stats.hidden = false;
                greetTail.textContent = `, ${name}!`;
                welcome.textContent = `Schön, dass du da bist. Schau dir die Videos an und sammle XP — alles gratis.`;
                display.textContent = name;
            } else {
                setup.hidden = false;
                stats.hidden = true;
                greetTail.textContent = '!';
                welcome.textContent = `Erzähl mir deinen Namen — dann zeige ich dir deine ersten Tricks.`;
            }

            // any element with data-name-template gets {name} substituted (or "Spieler" as fallback)
            const fallback = name || 'Spieler';
            document.querySelectorAll('[data-name-template]').forEach(el => {
                el.innerHTML = el.dataset.nameTemplate.replace(/\{name\}/g, fallback);
            });
        }

        function updateXP(animate = false) {
            const el = document.getElementById('xpNum');
            el.textContent = State.getXP();
            if (animate) {
                el.classList.remove('pop');
                // force reflow so the animation restarts
                void el.offsetWidth;
                el.classList.add('pop');
                setTimeout(() => el.classList.remove('pop'), 280);
            }
        }

        // ===== THEME TOGGLE =====
        function initThemeToggle() {
            const tog = document.getElementById('themeToggle');
            if (!tog) return;
            let theme = localStorage.getItem('t7_theme') || 'dark';
            const apply = () => {
                document.documentElement.setAttribute('data-theme', theme);
                document.body.setAttribute('data-theme', theme);
                tog.innerHTML = theme === 'dark' ? '☾' : '☀';
            };
            apply();
            tog.addEventListener('click', () => {
                theme = theme === 'dark' ? 'light' : 'dark';
                localStorage.setItem('t7_theme', theme);
                apply();
            });
        }

        // ===== INIT =====
        document.addEventListener('DOMContentLoaded', () => {
            initThemeToggle();
            updateName();
            updateXP();

            document.getElementById('nameSave').addEventListener('click', () => {
                const input = document.getElementById('nameInput');
                const name = input.value.trim();
                if (!name) return;
                State.setName(name);
                input.value = '';
                updateName();
            });
            document.getElementById('nameInput').addEventListener('keydown', e => {
                if (e.key === 'Enter') document.getElementById('nameSave').click();
            });
            document.getElementById('changeName').addEventListener('click', () => {
                State.clearName();
                updateName();
                document.getElementById('nameInput').focus();
            });

            renderGrid('stars', 'grid-stars');
            renderGrid('sevens', 'grid-sevens');
            renderGrid('challenges', 'grid-challenges');
        });
    </script>
</body>
</html>